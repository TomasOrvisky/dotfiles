general {
    colors = true
    color_good = "#a6e3a1"
    color_degraded = "#f9e2af"
    color_bad = "#f38ba8"
    interval = 5
}

order += "wireless _first_"
order += "cpu_usage"
order += "memory"
order += "battery all"
order += "volume master"
order += "tztime local"

wireless _first_ {
    format_up = "Wifi: %essid%quality"
    format_down = "WiFi off"
}

cpu_usage {
    format = "CPU %usage"
    degraded_threshold = 90
    max_threshold = 95
}

memory {
    format = "%used / %total"
    threshold_degraded = "1G"
    format_degraded = "LOW: %available"
}

battery all {
    format = "%status %percentage %remaining"
    low_threshold = 20
    threshold_type = percentage
}

volume master {
    format = "🔊 %volume"
    format_muted = "🔇 muted"
    device = "default"
    mixer = "Master"
    mixer_idx = 0
}

tztime local {
    format = "%d.%m.%Y %H:%M:%S"
}
